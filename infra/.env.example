# Postgres init (used by docker-compose)
POSTGRES_USER=tfm
POSTGRES_PASSWORD=tfm
POSTGRES_DB=tfm_rag

# Postgres
POSTGRES_URL=postgresql+asyncpg://tfm:tfm@postgres:5432/tfm_rag

# Qdrant
QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_LLM_MODEL=llama3.1
OLLAMA_DEFAULT_EMBEDDING_MODEL=bge-m3
# Per-request timeout (seconds) for Ollama calls. Default 300 — CPU inference
# of long prompts can be slow; raise it if you see client-side timeouts.
# OLLAMA_TIMEOUT=300
# Context window size (tokens) requested from Ollama models. Default 8192 —
# larger values use more RAM and are slower on CPU.
# OLLAMA_NUM_CTX=8192

# Auth
JWT_SECRET=replace_with_random_32_byte_string_xxxxx
JWT_EXPIRES_HOURS=24
FERNET_KEY=replace_with_fernet_key_generated_with_cryptography
# httpOnly auth cookie: Secure flag on the auth cookie. Must be true in
# production (HTTPS) — browsers drop Secure cookies over plain HTTP, so keep
# this false for local/dev.
# COOKIE_SECURE=false
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/data/storage
# Only used when STORAGE_BACKEND=s3.
# STORAGE_S3_BUCKET=
# STORAGE_S3_REGION=

# Logging
LOG_LEVEL=INFO

# Public-chat rate limiting (in-process token bucket per public_key + client IP).
# Defaults shown; tune for your traffic. There is no distributed/Redis limiter.
# PUBLIC_CHAT_RATE_PER_MINUTE=20
# PUBLIC_CHAT_BURST=5

# CORS
FRONTEND_ORIGIN=http://localhost:3000

# --- Test source databases (plan #9 CAP-KB-DB-SOURCES) ---
# Used by the `mysql_source` compose service (docker-compose.yml always,
# docker-compose.prod.yml only under `--profile demo`).
MYSQL_ROOT_PASSWORD=rootpw
MYSQL_DATABASE=tfm_rag_source_test
MYSQL_USER=tfm
MYSQL_PASSWORD=tfm

# --- Eval-dataset SQL provisioning (backend Settings; admin connection the
#     app uses to create/reset the per-run test MySQL schemas) ---
# EVAL_MYSQL_HOST=localhost
# EVAL_MYSQL_PORT=3306
# EVAL_MYSQL_ADMIN_USER=root
# EVAL_MYSQL_ADMIN_PASSWORD=rootpw

# --- SQL-source helper scripts (scripts/score-execution-accuracy.py,
#     scripts/verify-sql-references.py) — connect directly to the test MySQL
#     to score/verify SQL answers. Independent of the EVAL_MYSQL_* vars above.
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_ROOT_USER=root
# Full DSN override for verify-sql-references.py; if set, takes precedence
# over the individual MYSQL_HOST/PORT/USER/PASSWORD/DATABASE vars above.
# MYSQL_DSN=

# --- Eval judge / RAGAS scoring (backend eval routes + ragas_evaluator) ---
# Small, fast Ollama model used for the inline per-answer correctness check
# (separate from the RAGAS judge model configured per-run).
# EVAL_CORRECTNESS_JUDGE_MODEL=gemma3:1b
# API key for OpenAI-backed judge/generator models in eval runs (only needed
# if an eval credential selects an OpenAI model). Read by langchain-openai.
# OPENAI_API_KEY=
# RAGAS scoring tuning — defaults are usually fine; raise timeouts/retries
# for slow/local judge models, or increase workers for faster APIs.
# RAGAS_MAX_WORKERS=16
# RAGAS_TIMEOUT=180
# RAGAS_MAX_RETRIES=10
# RAGAS_MAX_WAIT=60
# RAGAS_JUDGE_MAX_RETRIES=8
